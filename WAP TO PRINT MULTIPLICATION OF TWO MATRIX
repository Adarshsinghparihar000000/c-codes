#include<stdio.h>
int main(){
    int M,N,P;
    //INPUT MATRIX DIMENSIONS
    printf("enter the number of rows and columns of matrix A(M,N):\n ");
    scanf("%d%d",&M,&N);
    printf("enter the number of columns of matrix B(N,P):");
    scanf("%d",&P);
    
    int A[M][N],B[N][P],C[M][P];
    
    //input matrix A
    
    printf("enter the elements of matrix A:\n");
    for(int i=0;i<M;i++){
        for(int j=0;j<N;j++){
            scanf("%d",&A[i][j]);
        }
        printf("\n");
    }
    //input matrix B
    
    printf("enter the elements of matrix B:\n");
     for(int i=0;i<N;i++){
        for(int j=0;j<P;j++){
            scanf("%d",&B[i][j]);
        }
        printf("\n");
    }
    
    //initialize result matrix C with 0
    
    for(int i=0;i<M;i++){
        for(int j=0;j<P;j++){
            C[i][j]=0;
        }
    }
    
    //multiplication of matrix
    
    for(int i=0;i<M;i++){
        for(int j=0;j<P;j++){
            for(int k=0;k<N;k++){
                C[i][j] += A[i][k]*B[k][j];
                
            }
        }
    }
    
    //print result
    printf("resultant matrix C(M,P):\n");
    for(int i=0;i<M;i++){
        for(int j=0;j<P;j++){
            printf("%d",C[i][j]);
        }
        printf("\n");
    }
    return 0;
}
