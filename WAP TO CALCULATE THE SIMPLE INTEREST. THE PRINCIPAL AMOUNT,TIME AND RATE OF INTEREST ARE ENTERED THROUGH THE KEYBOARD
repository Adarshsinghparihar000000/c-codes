#include<stdio.h>
#include<math.h>
int main(){
    float p,r,t,s,c;
    printf("enter the values of principal amount,rate and time to find simple and compound interest:\n");
    scanf("%f%f%f,&p,&r,&t");
    s=(p*r*t)/100;
    c=(p*pow(1+r/100),t)-p;
    printf("the simple interest is %f\n and the compound interest is %f\n",s,c);
    return 0;
}
