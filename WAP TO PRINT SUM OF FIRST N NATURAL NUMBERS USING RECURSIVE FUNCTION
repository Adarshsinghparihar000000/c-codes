#include<stdio.h>

int sum(int n);

int main(){
    int n;
    printf("enter a number n to calculate the sum of first n natural numbers :\n");
    scanf("%d",&n);
    printf("SUM OF FIRST %d NATURAL NUMBERS:%d",n,sum(n));
    return 0;
}

int sum(int n){
    if(n==1){
        return 1;
    }
    int sumNm1=sum(n-1);
    int sumN=sumNm1 + n;
    return sumN;
}
