#include<stdio.h>

int factorial(int n);

int main(){
    int n;
    printf("enter a number n to calculate factorial of n:\n");
    scanf("%d",&n);
    printf("THE FACTORIAL OF %d : %d",n,factorial(n));
    return 0;
}

int factorial(int n){
    if(n==1){
        return 1;
    }
    int factorialNm1=factorial(n-1);
    int factorialN=factorialNm1*n;
    return factorialN;
}
