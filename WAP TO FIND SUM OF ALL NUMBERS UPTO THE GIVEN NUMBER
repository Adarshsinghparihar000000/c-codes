#include<stdio.h>
int main (){
    int n;
    printf("enter a number n to find the sum of all numbers upto the given number:\n");
    scanf("%d",&n);
    int sum =0;
    for(int i=1;i<=n;i++){
        sum = sum+i;
    }
    printf("the sum of all numbers upto given numbers is %d\n",sum);
    return 0;
}
